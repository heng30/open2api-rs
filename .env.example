# Open2API Configuration Example
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Backend Configuration (supports multiple backends)
# Format: BACKEND_<ID>_BASE_URL, BACKEND_<ID>_API_KEY, BACKEND_<ID>_NAME

# Primary Claude Backend (Anthropic API)
BACKEND_1_BASE_URL=https://api.anthropic.com
BACKEND_1_API_KEY=sk-ant-xxx
BACKEND_1_NAME=claude-primary

# Backup Backend (custom Claude-compatible API)
BACKEND_2_BASE_URL=https://api.custom.com
BACKEND_2_API_KEY=sk-xxx
BACKEND_2_NAME=claude-backup

# Optional: Additional backends
# BACKEND_3_BASE_URL=https://api.another.com
# BACKEND_3_API_KEY=sk-yyy
# BACKEND_3_NAME=claude-third

# Logging Configuration
RUST_LOG=info