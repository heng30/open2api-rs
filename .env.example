# Hacker News RSS Generator Configuration
# Copy this file to .env and fill in your values

# === Server Configuration ===
# Port to run the server on (default: 3000)
HACKER_NEWS_PORT=3000

# Database URL (default: sqlite:data/hacker_news.db?mode=rwc)
# Examples:
#   - Local SQLite: sqlite:data/hacker_news.db?mode=rwc
#   - Absolute path: sqlite:/var/lib/hacker_news/hacker_news.db?mode=rwc
#   - In-memory (for testing): sqlite::memory:
HACKER_NEWS_DATABASE_URL=sqlite:data/hacker_news.db?mode=rwc

# === LLM Configuration (Sensitive - Use Environment Variables) ===
# OpenAI API key (required for LLM summarization)
# This is the most sensitive value - NEVER store in database or expose in API
# HACKER_NEWS_OPENAI_API_KEY=your_api_key_here

# OpenAI API base URL (default: https://api.openai.com/v1)
# Can be changed to use OpenAI-compatible APIs (e.g., Azure, Alibaba Cloud, local LLM)
# Examples:
#   - OpenAI: https://api.openai.com/v1
#   - Alibaba Cloud (Qwen): https://coding.dashscope.aliyuncs.com/v1
#   - Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   - Local Ollama: http://localhost:11434/v1
HACKER_NEWS_OPENAI_BASE_URL=https://api.deepseek.com/v1

# Model to use for summarization (default: deepseek-chat)
# Examples: gpt-4o, gpt-4o-mini, qwen-plus, qwen-turbo
HACKER_NEWS_MODEL=deepseek-chat

# Auto update interval in minutes (default: 0, disabled)
# Set to 0 to disable automatic fetching
# Set to 60 to fetch every hour, 30 for every 30 minutes, etc.
HACKER_NEWS_AUTO_UPDATE_INTERVAL=0

# Search keywords for Algolia HN Search (optional)
# Comma-separated list of keywords to search for additional stories
# Stories from keyword search will be marked with a tag badge in the UI
# Example: "rust,go,linux,ai" will search for stories about these topics
# HACKER_NEWS_SEARCH_KEYWORDS=rust,go,linux

# SOCKS5 proxy for API requests (optional)
# Useful for accessing HN/Algolia APIs in restricted networks
# Example: 127.0.0.1:1080 or socks5://127.0.0.1:1080
# HACKER_NEWS_SOCKS5=127.0.0.1:1080

# Disable streaming mode (default: auto-detect based on API URL)
# Some APIs (like coding.dashscope.aliyuncs.com) don't support streaming
# Set to "true" to force non-streaming mode
# HACKER_NEWS_LLM_NO_STREAM=false

# Custom User-Agent for LLM requests (default: reqwest default)
# Some APIs reject the default reqwest User-Agent
# Example: "curl/8.0" or "Mozilla/5.0"
# HACKER_NEWS_LLM_USER_AGENT=curl/8.0
#
# LLM API request timeout in seconds (default: 180)
# Increase if using slower models or APIs with high latency
# HACKER_NEWS_LLM_TIMEOUT=180

# HTML content fetch timeout in seconds (default: 30)
# Timeout for fetching article content from external URLs
# HACKER_NEWS_FETCH_HTML_TIMEOUT=30

# Maximum content length in characters (default: 16000)
# Content exceeding this limit will be truncated before sending to LLM
# Increase for longer articles, decrease to save tokens
# HACKER_NEWS_MAX_CONTENT_LENGTH=16000

# Minimum score for top stories to be fetched (default: 500)
# Only stories with score >= this value will be processed
# Increase for higher quality threshold, decrease for more stories
# Example: 500 for popular stories, 1000 for very popular, 100 for broader coverage
# HACKER_NEWS_TOP_STORY_MIN_SCORE=500

# Summary generation concurrency (default: 3)
# Number of summaries to generate concurrently in each batch
# Increase for faster processing if API rate limits allow, decrease to avoid rate limiting
# Example: 5 for faster processing, 1 for sequential processing
# HACKER_NEWS_SUMMARY_CONCURRENCY=3
