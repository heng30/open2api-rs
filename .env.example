# Open2API Configuration Example
# Copy this file to .env and fill in your values

# Server Configuration
OPEN2API_HOST=0.0.0.0
OPEN2API_PORT=8080

# Frontend Authentication (optional)
# Comma-separated for multiple keys. If not set, all endpoints are publicly accessible.
# OPEN2API_API_KEYS=key1,key2,key3

# Backend Configuration (Alibaba Cloud Bailian Coding Agent)
OPEN2API_BACKEND_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
OPEN2API_BACKEND_API_KEY=sk-xxx
OPEN2API_MODELS=qwen3.5-plus,glm-5,glm-4.7,kimi-k2.5,MiniMax-M2.5

# Default max tokens for Claude requests (defaults to 64k if not set)
# OPEN2API_DEFAULT_MAX_TOKENS=65535

# Logging Configuration (optional)
RUST_LOG=info
